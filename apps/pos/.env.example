# Float0 POS — Environment Configuration
#
# API_URL: The Engine backend URL
EXPO_PUBLIC_API_URL=http://localhost:4000

# SYNC_INTERVAL_MS: How often the POS syncs data from the server (ms)
EXPO_PUBLIC_SYNC_INTERVAL_MS=30000

# ORG_ID: The organization UUID from the database.
# Run `pnpm --filter @float0/engine seed` to create demo data,
# then copy the printed Organization ID here.
EXPO_PUBLIC_ORG_ID=
