{
  "name": "float0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "docker compose up -d || true; turbo run dev --filter=@float0/engine --filter=@float0/hub --filter=@float0/portal & turbo run dev:sim --filter=@float0/pos",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@eslint/js": "^9",
    "@next/eslint-plugin-next": "^14.2.23",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-native": "^4",
    "globals": "^15",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "bcrypt",
      "esbuild"
    ]
  }
}
