{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "paths": {
      "@float0/shared": ["./packages/shared/src"],
      "@float0/shared/*": ["./packages/shared/src/*"],
      "@float0/ui": ["./packages/ui/src"],
      "@float0/ui/*": ["./packages/ui/src/*"],
      "@float0/events": ["./packages/events/src"],
      "@float0/events/*": ["./packages/events/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
